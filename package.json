{
  "name": "dmx-tools",
  "version": "1.0.0",
  "description": "Free DMX Utilities developed by Alessandro Caseti",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "vercel-build": "echo \"Skipping electron build on Vercel\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alessandrocaseti/dmx-tools.git"
  },
  "author": "Alessandro Caseti",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/alessandrocaseti/dmx-tools/issues"
  },
  "homepage": "https://github.com/alessandrocaseti/dmx-tools#readme",
  "dependencies": {
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "build":
  {
    "appId": "dmxtools",
    "productName": "dmxtools",
    "directories":{
      "output": "dist"
    },
    "win":{
      "target":"nsis"
    },
    "mac":{
      "target":"dmg"
    },
    "linux":{
    "target":"AppImage"
    }
  }
}